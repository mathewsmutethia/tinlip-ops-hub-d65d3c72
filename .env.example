# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Sentry — error tracking (optional, set in Vercel env vars)
VITE_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# Sentry source map upload (optional, set in Vercel build env)
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=tinlip-admin

# PostHog — user analytics (optional, set in Vercel env vars)
VITE_POSTHOG_KEY=phc_xxxx
VITE_POSTHOG_HOST=https://app.posthog.com
